meta {
  name: Apply Framing - Paragraphs Only
  type: http
  seq: 6.1
}

put {
  url: {{base_url}}/documents/{{document_id}}/format
  body: json
  auth: none
}

body:json {
  {
    "framing": {
      "sections": false,
      "paragraphs": true,
      "subparagraphs": false,
      "sentences": false
    }
  }
}

assert {
  res.status: eq 200
  res.body.success: eq true
  res.body.output_path: isDefined
  res.body.borders_applied: isDefined
}

docs {
  # Apply Framing - Paragraphs Only

  Test per applicare bordi solo ai paragrafi.

  ## Request
  ```json
  {
    "framing": {
      "sections": false,
      "paragraphs": true,
      "subparagraphs": false,
      "sentences": false
    }
  }
  ```

  ## Expected Behavior
  - Solo i paragrafi avranno bordi
  - Le sezioni non avranno bordi
  - Output file: `edited_[filename].docx`
}

